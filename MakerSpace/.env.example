# Azure OpenAI endpoint for your Foundry resource
# Use the base resource URL (without /api/projects/...)
AZURE_OPENAI_ENDPOINT=https://foundry-project.services.ai.azure.com/

# The deployment name you configured in Foundry
AZURE_OPENAI_DEPLOYMENT_NAME=gpt-5.4-mini

# Your Azure OpenAI API key (if using key-based authentication)
AZURE_OPENAI_API_KEY=your_api_key_here